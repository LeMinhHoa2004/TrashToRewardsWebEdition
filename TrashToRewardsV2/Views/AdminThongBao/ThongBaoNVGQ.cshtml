@model IEnumerable<TrashToRewardsV2.Models.THONGBAONVGQ>
@{
    ViewData["Title"] = "Quản lý thông báo nhân viên giao quà";
}

<div class="container py-4">
    <div class="bg-white rounded p-4 shadow-sm mb-4">
        <h2 class="fw-bold text-success mb-4">Thông báo nhân viên giao quà</h2>

        <!-- Form gửi thông báo hàng loạt -->
        <form asp-action="SendBulkToNhanVienGQ" method="post" class="mb-4">
            <div class="input-group">
                <input type="text" name="noiDung" class="form-control rounded-start" placeholder="Nhập nội dung thông báo chung" required />
                <button type="submit" class="btn btn-success px-4">Gửi tất cả nhân viên giao quà</button>
            </div>
        </form>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="CreateNVGQ" class="btn btn-success">
                <i class="bi bi-plus-circle me-2"></i>Thêm thông báo mới
            </a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0">Nhân viên giao quà</th>
                                <th class="border-0">Nội dung</th>
                                <th class="border-0">Ngày tạo</th>
                                <th class="border-0">Trạng thái</th>
                                <th class="border-0 text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tb in Model)
                            {
                                <tr>
                                    <td>@tb.NHANVIENGQ?.HoTenNVGQ</td>
                                    <td>@tb.NoiDungNVGQ</td>
                                    <td>@tb.NgayTaoNVGQ.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (tb.DaDoc)
                                        {
                                            <span class="badge bg-success">Đã đọc</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Chưa đọc</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <a asp-action="DetailsNVGQ" asp-route-id="@tb.MaTBNVGQ" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-info-circle"></i>
                                            </a>
                                            <a asp-action="EditNVGQ" asp-route-id="@tb.MaTBNVGQ" class="btn btn-sm btn-outline-warning">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="DeleteNVGQ" asp-route-id="@tb.MaTBNVGQ" method="post" class="d-inline" onsubmit="return confirm('Bạn chắc chắn muốn xóa?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>