@model TrashToRewardsV2.Models.THONGBAONV

@{
    ViewData["Title"] = "Chỉnh sửa thông báo Nhân viên";
}

<div class="container py-4">
    <div class="bg-white rounded p-4 shadow-sm mb-4">
        <h2 class="fw-bold text-success mb-4">Chỉnh Sửa Thông Báo Nhân Viên</h2>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <form asp-action="EditNV" method="post">
                            @Html.AntiForgeryToken()
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                            }

                            <input type="hidden" asp-for="MaTBNV" />

                            <div class="mb-4">
                                <label asp-for="MaNV" class="form-label fw-medium">Nhân viên</label>
                                <select asp-for="MaNV" asp-items="ViewBag.NhanVienList" class="form-select"></select>
                            </div>

                            <div class="mb-4">
                                <label asp-for="NoiDungNV" class="form-label fw-medium">Nội dung thông báo</label>
                                <textarea asp-for="NoiDungNV" class="form-control" rows="5" placeholder="Nhập nội dung thông báo..."></textarea>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success px-4">
                                    <i class="bi bi-check-circle me-2"></i>Lưu thay đổi
                                </button>
                                <a asp-action="ThongBaoNV" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>