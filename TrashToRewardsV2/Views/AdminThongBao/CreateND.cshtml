@model TrashToRewardsV2.Models.THONGBAOND

@{
    ViewData["Title"] = "Tạo thông báo Người dùng";
}

<div class="container py-4">
    <div class="bg-white bg-opacity-75 rounded shadow-sm p-4">
        <h2 class="mb-4 fw-bold text-success">Tạo Thông Báo Người Dùng</h2>

        <form asp-action="CreateND" method="post" class="card border-0 shadow-sm p-4">
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
            }

            <div class="mb-4">
                <label asp-for="MaND" class="form-label fw-bold">Người dùng</label>
                <select asp-for="MaND" asp-items="ViewBag.NguoiDungList" class="form-select">
                    <option value="">-- Chọn người dùng --</option>
                </select>
            </div>

            <div class="mb-4">
                <label asp-for="NoiDungND" class="form-label fw-bold">Nội dung thông báo</label>
                <textarea asp-for="NoiDungND" class="form-control" rows="5" placeholder="Nhập nội dung thông báo..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4 rounded-pill">
                    <i class="bi bi-check-circle me-2"></i>Tạo thông báo
                </button>
                <a asp-action="ThongBaoND" class="btn btn-outline-secondary px-4 rounded-pill">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </form>
    </div>
</div>