@model TrashToRewardsV2.Models.THONGBAONV

@{
    ViewData["Title"] = "Tạo thông báo Nhân viên";
}

<div class="container py-4">
    <div class="bg-white bg-opacity-75 rounded shadow-sm p-4">
        <h2 class="mb-4 fw-bold text-success">Tạo Thông Báo Nhân Viên</h2>

        <form asp-action="CreateNV" method="post" class="card border-0 shadow-sm p-4">
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
            }

            <div class="mb-4">
                <label asp-for="MaNV" class="form-label fw-bold">Nhân viên</label>
                <select asp-for="MaNV" asp-items="ViewBag.NhanVienList" class="form-select">
                    <option value="">-- Chọn nhân viên --</option>
                </select>
            </div>

            <div class="mb-4">
                <label asp-for="NoiDungNV" class="form-label fw-bold">Nội dung thông báo</label>
                <textarea asp-for="NoiDungNV" class="form-control" rows="5" placeholder="Nhập nội dung thông báo..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4 rounded-pill">
                    <i class="bi bi-check-circle me-2"></i>Tạo thông báo
                </button>
                <a asp-action="ThongBaoNV" class="btn btn-outline-secondary px-4 rounded-pill">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </form>
    </div>
</div>