<!DOCTYPE html>
<html lang="en">

@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@using TrashToRewardsV2.Models
@inject ApplicationDbContext Context

@{
    var user = HttpContextAccessor.HttpContext.User;
    bool isAuthenticated = user.Identity.IsAuthenticated;
    bool isAdmin = user.IsInRole("ADMIN");
    bool isStaff = user.IsInRole("NHANVIEN");
    bool isStaffGQ = user.IsInRole("NHANVIENGQ");
    bool isUser = user.IsInRole("NGUOIDUNG");


    int soThongBaoChuaDoc = 0;
    List<object> danhSachThongBao = new();

    if (isAuthenticated)
    {
        if (isUser)
        {
            int maND = int.Parse(user.FindFirst("MaND").Value);
            soThongBaoChuaDoc = Context.THONGBAOND.Count(tb => tb.MaND == maND && !tb.DaDoc);
            danhSachThongBao = Context.THONGBAOND
                .Where(tb => tb.MaND == maND)
                .OrderByDescending(tb => tb.NgayTaoND)
                .Take(5)
                .Cast<object>()
                .ToList();
        }
        else if (isStaff)
        {
            int maNV = int.Parse(user.FindFirst("MaNV").Value);
            soThongBaoChuaDoc = Context.THONGBAONV.Count(tb => tb.MaNV == maNV && !tb.DaDoc);
            danhSachThongBao = Context.THONGBAONV
                .Where(tb => tb.MaNV == maNV)
                .OrderByDescending(tb => tb.NgayTaoNV)
                .Take(5)
                .Cast<object>()
                .ToList();
        }
        else if (isStaffGQ)
        {
            int maNVGQ = int.Parse(user.FindFirst("MaNVGQ").Value);
            soThongBaoChuaDoc = Context.THONGBAONVGQ.Count(tb => tb.MaNVGQ == maNVGQ && !tb.DaDoc);
            danhSachThongBao = Context.THONGBAONVGQ
                .Where(tb => tb.MaNVGQ == maNVGQ)
                .OrderByDescending(tb => tb.NgayTaoNVGQ)
                .Take(5)
                .Cast<object>()
                .ToList();
        }
    }
}

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="TrashToRewards - Đổi rác lấy quà" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>@ViewData["Title"] - TrashToRewards</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TrashToRewardsV2.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    @if (User.Identity.IsAuthenticated)
    {
        <meta name="isLoggedIn" content="true" />
        <meta name="userRole" content="@(isUser ? "NGUOIDUNG" : (isStaff ? "NHANVIEN" : (isStaffGQ ? "NHANVIENGQ" : "")))" />
        <meta name="userId" content="@(isUser ? user.FindFirst("MaND").Value : (isStaff ? user.FindFirst("MaNV").Value : (isStaffGQ ? user.FindFirst("MaNVGQ").Value : "")))" />
    }

</head>

<body>
    <header>
        <!-- Navbar mới với thiết kế tương đồng với Home/Index -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo2.png" alt="Logo" style="height: 60px;" />
                    
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-fill"></i> Trang chủ
                            </a>
                        </li>
                        @if (isAuthenticated)
                        {
                            @if (isUser)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="PhieuDatLich" asp-action="Create">
                                        <i class="bi bi-calendar-plus"></i> Đặt lịch mới
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="PhieuDoiQua" asp-action="Index">
                                        <i class="bi bi-gift"></i> Đổi quà
                                    </a>
                                </li>
                            }
                            else if (isStaff)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="PhieuDatLich" asp-action="List">
                                        <i class="bi bi-calendar-check"></i> Lịch thu gom
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="PhieuThuGom" asp-action="Index">
                                        <i class="bi bi-recycle"></i> Thu gom
                                    </a>
                                </li>
                            }
                        }
                        @if (isAuthenticated && isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-speedometer2"></i> Dashboard
                                </a>
                            </li>
                        }
                        else if (isAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-grid-3x3-gap-fill"></i> Tài khoản
                                </a>
                                <ul class="dropdown-menu shadow border-0">
                                    @if (isAdmin)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Profile"><i class="bi bi-person me-2"></i>Thông tin cá nhân</a></li>
                                    }
                                    else if (isStaff)
                                    {
                                        <li><a class="dropdown-item" asp-controller="NhanVien" asp-action="Profile"><i class="bi bi-person me-2"></i>Thông tin cá nhân</a></li>
                                        <li><a class="dropdown-item" asp-controller="PhieuDatLich" asp-action="List"><i class="bi bi-calendar-check me-2"></i>Quản lý đặt lịch</a></li>
                                        <li><a class="dropdown-item" asp-controller="PhieuThuGom" asp-action="Index"><i class="bi bi-recycle me-2"></i>Quản lý thu gom</a></li>
                                        <li><a class="dropdown-item" asp-controller="PhieuGhiNhan" asp-action="Index"><i class="bi bi-clipboard-check me-2"></i>Phiếu ghi nhận</a></li>
                                        <li><a class="dropdown-item" asp-controller="LoaiPheLieu" asp-action="Index"><i class="bi bi-arrow-repeat me-2"></i>Tỉ lệ quy đổi</a></li>
                                    }
                                    else if (isStaffGQ)
                                    {
                                        <li><a class="dropdown-item" asp-controller="NhanVienGQ" asp-action="Profile"><i class="bi bi-person me-2"></i>Thông tin cá nhân</a></li>
                                        <li><a class="dropdown-item" asp-controller="NhanVienGQPhieuDoiQua" asp-action="Index"><i class="bi bi-gift me-2"></i>Quản lý giao quà</a></li>
                                        <li><a class="dropdown-item" asp-controller="NhanVienGQ" asp-action="DanhSachPhanThuongTrongKho"><i class="bi bi-box me-2"></i>Phần thưởng trong kho</a></li>
                                    }
                                    else if (isUser)
                                    {
                                        <li><a class="dropdown-item" asp-controller="NguoiDung" asp-action="Profile"><i class="bi bi-person me-2"></i>Thông tin cá nhân</a></li>
                                        <li><a class="dropdown-item" asp-controller="PhieuDatLich" asp-action="Index"><i class="bi bi-calendar-check me-2"></i>Quản lý đặt lịch</a></li>
                                        <li><a class="dropdown-item" asp-controller="LichSuTichDiem" asp-action="Index"><i class="bi bi-clock-history me-2"></i>Lịch sử tích điểm</a></li>
                                        <li><a class="dropdown-item" asp-controller="PhieuDoiQua" asp-action="Index"><i class="bi bi-gift me-2"></i>Đổi quà</a></li>
                                        <li><a class="dropdown-item" asp-controller="NguoiDungPhieu" asp-action="PhieuThuGom"><i class="bi bi-recycle me-2"></i>Phiếu thu gom của bạn</a></li>
                                        <li><a class="dropdown-item" asp-controller="NguoiDungPhieu" asp-action="PhieuGhiNhan"><i class="bi bi-clipboard-check me-2"></i>Phiếu ghi nhận của bạn</a></li>
                                        
                                        <li><a class="dropdown-item" asp-controller="NguoiDungPhieu" asp-action="PhanThuong"><i class="bi bi-gift me-2"></i>Các phần quà</a></li>
                                        <li><a class="dropdown-item" asp-controller="NguoiDungPhieu" asp-action="KhoQua"><i class="bi bi-box-seam me-2"></i>Danh sách các kho quà</a></li>
                                        <li><a class="dropdown-item" asp-controller="LoaiPheLieu" asp-action="Index"><i class="bi bi-arrow-repeat me-2"></i>Tỉ lệ quy đổi</a></li>
                                        <li><a class="dropdown-item" asp-controller="NguoiDung" asp-action="DonViThuGom"><i class="bi bi-map me-2"></i>Danh sách các điểm thu gom</a></li>
                                    }
                                </ul>
                            </li>
                        }
                        @if (isAuthenticated && (isUser || isStaff || isStaffGQ))
                        {
                            <li class="nav-item dropdown mx-2">
                                <a class="nav-link position-relative text-white" href="#" id="alertsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell-fill fs-5"></i>
                                    @if (soThongBaoChuaDoc > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                            @(soThongBaoChuaDoc > 99 ? "99+" : soThongBaoChuaDoc.ToString())
                                        </span>
                                    }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="alertsDropdown" style="min-width: 320px; max-height: 400px; overflow-y: auto;">
                                    <li class="dropdown-header bg-success text-white py-2 px-3 d-flex justify-content-between align-items-center">
                                        <span>Thông báo</span>
                                        <span class="badge bg-light text-success rounded-pill">@soThongBaoChuaDoc mới</span>
                                    </li>
                                    @if (danhSachThongBao != null && danhSachThongBao.Count > 0)
                                    {
                                        @foreach (dynamic tb in danhSachThongBao)
                                        {
                                            <li class="notification-item px-3 py-2 border-bottom hover-card">
                                                <div class="small fw-bold text-success">Thông báo từ hệ thống</div>
                                                <div class="text-dark">
                                                    @(isUser ? tb.NoiDungND :
                                                        isStaff ? tb.NoiDungNV :
                                                        isStaffGQ ? tb.NoiDungNVGQ : "")
                                                </div>
                                                <div class="text-end text-muted fst-italic small">
                                                    @((isUser ? tb.NgayTaoND :
                                                        isStaff ? tb.NgayTaoNV :
                                                        isStaffGQ ? tb.NgayTaoNVGQ :
                                                        DateTime.MinValue).ToString("dd/MM/yyyy HH:mm"))
                                                </div>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li class="px-3 py-2 text-muted text-center">Không có thông báo</li>
                                    }
                                    <li><hr class="dropdown-divider m-0" /></li>
                                    <li>
                                        <a class="dropdown-item text-center text-success py-2" href="@(
                                            isUser ? Url.Action("NguoiDung", "ThongBao") :
                                            isStaff ? Url.Action("NhanVien", "ThongBao") :
                                            isStaffGQ ? Url.Action("NhanVienGQ", "ThongBao") :
                                            "#"
                                        )">
                                            <i class="bi bi-eye"></i> Xem tất cả
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (!isAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus"></i> Đăng ký
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <div class="bg-white text-success rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 30px; height: 30px;">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <span>@user.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userDropdown">
                                    @if (isAdmin)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">
                                                <i class="bi bi-speedometer2 me-2 text-success"></i> Dashboard
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Profile">
                                                <i class="bi bi-person me-2 text-success"></i> Tài khoản (Admin)
                                            </a>
                                        </li>
                                    }
                                    else if (isStaff)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="NhanVien" asp-action="Profile">
                                                <i class="bi bi-person me-2 text-success"></i> Tài khoản (Nhân viên)
                                            </a>
                                        </li>
                                    }
                                    else if (isStaffGQ)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="NhanVienGQ" asp-action="Profile">
                                                <i class="bi bi-person me-2 text-success"></i> Tài khoản (Nhân viên giao quà)
                                            </a>
                                        </li>
                                    }
                                    else if (isUser)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="NguoiDung" asp-action="Profile">
                                                <i class="bi bi-person me-2 text-success"></i> Tài khoản
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <!-- Footer được cải tiến -->
    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5 class="text-success mb-3 fw-bold">TrashToRewards</h5>
                    <p class="mb-3">Biến rác thải thành phần thưởng - Vì một môi trường xanh sạch đẹp</p>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-white"><i class="bi bi-facebook fs-5"></i></a>
                        <a href="#" class="text-white"><i class="bi bi-youtube fs-5"></i></a>
                    </div>
                </div>
                <div class="col-lg-4">
                    <h5 class="text-success mb-3 fw-bold">Liên kết nhanh</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#" class="text-white text-decoration-none"><i class="bi bi-chevron-right me-1 text-success"></i> Về chúng tôi</a></li>
                        <li class="mb-2"><a href="#" class="text-white text-decoration-none"><i class="bi bi-chevron-right me-1 text-success"></i> Dịch vụ</a></li>
                        <li class="mb-2"><a href="#" class="text-white text-decoration-none"><i class="bi bi-chevron-right me-1 text-success"></i> Đối tác</a></li>
                        <li class="mb-2"><a href="#" class="text-white text-decoration-none"><i class="bi bi-chevron-right me-1 text-success"></i> Tin tức</a></li>
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-white text-decoration-none"><i class="bi bi-chevron-right me-1 text-success"></i> Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h5 class="text-success mb-3 fw-bold">Liên hệ</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2 d-flex align-items-start">
                            <i class="bi bi-geo-alt-fill text-success me-2 mt-1"></i>
                            <span>123 Đường Xanh, Quận Sạch, TP. Môi Trường</span>
                        </li>
                        <li class="mb-2 d-flex align-items-start">
                            <i class="bi bi-telephone-fill text-success me-2 mt-1"></i>
                            <span>+84 123 456 789</span>
                        </li>
                        <li class="mb-2 d-flex align-items-start">
                            <i class="bi bi-envelope-fill text-success me-2 mt-1"></i>
                            <span>zzzthenew1@gmail.com</span>
                        </li>
                    </ul>
                </div>
            </div>
            <hr class="mt-4 mb-3 bg-secondary">
            <div class="row">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0">&copy; 2025 - TrashToRewards - Đổi rác lấy quà</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <p class="mb-0">Phát triển bởi <span class="text-success">TrashToRewardsTeam</span></p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/thongbao.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>