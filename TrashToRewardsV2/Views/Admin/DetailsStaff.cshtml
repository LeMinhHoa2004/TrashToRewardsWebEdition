@model TrashToRewardsV2.Models.NHANVIEN
@{
    ViewData["Title"] = "Chi tiết nhân viên";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-lg-5 p-4">
                    <div class="d-flex align-items-center mb-4">
                        <i class="bi bi-person-badge-fill text-success fs-1 me-3"></i>
                        <h2 class="fw-bold text-success mb-0">Chi tiết nhân viên</h2>
                    </div>

                    <hr class="my-4">

                    <div class="text-center mb-4">
                        <div class="avatar bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                            <i class="bi bi-person-fill text-success" style="font-size: 3rem;"></i>
                        </div>
                        <h3 class="fw-bold">@Model.HoTenNV</h3>
                        @if (Model.DONVITHUGOM != null)
                        {
                            <span class="badge bg-success rounded-pill">@Model.DONVITHUGOM.TenDV</span>
                        }
                    </div>

                    <div class="bg-light p-4 rounded-3 mb-4">
                        <dl class="row mb-0">
                            <dt class="col-sm-3 fw-semibold">
                                <i class="bi bi-envelope-fill text-success me-2"></i>Email:
                            </dt>
                            <dd class="col-sm-9">@Model.EmailNV</dd>

                            <dt class="col-sm-3 fw-semibold">
                                <i class="bi bi-telephone-fill text-success me-2"></i>Số điện thoại:
                            </dt>
                            <dd class="col-sm-9">@Model.SDTNV</dd>

                            <dt class="col-sm-3 fw-semibold">
                                <i class="bi bi-building-fill text-success me-2"></i>Đơn vị thu gom:
                            </dt>
                            <dd class="col-sm-9">
                                @if (Model.DONVITHUGOM != null)
                                {
                                    @Model.DONVITHUGOM.TenDV
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Chưa được phân đơn vị</span>
                                }
                            </dd>
                        </dl>
                    </div>

                    <div class="text-center mt-4">
                        <a asp-action="Dashboard" class="btn btn-outline-success rounded-pill px-4">
                            <i class="bi bi-arrow-left me-2"></i>Quay lại Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}