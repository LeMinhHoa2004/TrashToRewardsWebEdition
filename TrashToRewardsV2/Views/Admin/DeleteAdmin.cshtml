@model TrashToRewardsV2.Models.ADMIN

@{
    ViewData["Title"] = "Xóa Admin";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded">
                <div class="card-body p-lg-5 p-4">
                    <h2 class="fw-bold text-success mb-4">Xác nhận xóa Admin</h2>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-warning rounded">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @TempData["Error"]
                        </div>

                        <div class="mt-4">
                            <a asp-action="Dashboard" class="btn btn-success px-4 rounded-pill">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại Dashboard
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger rounded mb-4">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            Bạn có chắc chắn muốn xóa admin <strong>@Model.HoTenAD</strong> không?
                        </div>

                        <form asp-action="DeleteAdminConfirmed" method="post">
                            <input type="hidden" asp-for="MaAD" />

                            <div class="d-flex gap-3">
                                <button type="submit" class="btn btn-danger px-4 rounded-pill">
                                    <i class="bi bi-trash-fill me-2"></i>Xóa
                                </button>
                                <a asp-action="Dashboard" class="btn btn-outline-secondary px-4 rounded-pill">
                                    <i class="bi bi-x-circle me-2"></i>Hủy
                                </a>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}