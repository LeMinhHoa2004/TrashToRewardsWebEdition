@model TrashToRewardsV2.Models.NGUOIDUNG
@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-lg-5 p-4">
                    <h2 class="fw-bold text-success mb-4">✏️ Chỉnh sửa người dùng</h2>

                    <form asp-action="EditUser" method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                        }
                        <input type="hidden" asp-for="MaND" />

                        <div class="mb-4">
                            <label asp-for="HoTen" class="form-label fw-medium">Họ tên</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0">
                                    <i class="bi bi-person-fill text-success"></i>
                                </span>
                                <input asp-for="HoTen" class="form-control border-0 bg-light" />
                            </div>
                            <span asp-validation-for="HoTen" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-medium">Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0">
                                    <i class="bi bi-envelope-fill text-success"></i>
                                </span>
                                <input asp-for="Email" class="form-control border-0 bg-light" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="SDT" class="form-label fw-medium">Số điện thoại</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0">
                                    <i class="bi bi-telephone-fill text-success"></i>
                                </span>
                                <input asp-for="SDT" class="form-control border-0 bg-light" />
                            </div>
                            <span asp-validation-for="SDT" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DiaChi" class="form-label fw-medium">Địa chỉ</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0">
                                    <i class="bi bi-geo-alt-fill text-success"></i>
                                </span>
                                <input asp-for="DiaChi" class="form-control border-0 bg-light" />
                            </div>
                            <span asp-validation-for="DiaChi" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="MatKhau" class="form-label fw-medium">Mật khẩu</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0">
                                    <i class="bi bi-lock-fill text-success"></i>
                                </span>
                                <input asp-for="MatKhau" type="text" class="form-control border-0 bg-light" />
                            </div>
                            <span asp-validation-for="MatKhau" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn btn-success px-4 py-2 rounded-pill fw-medium">
                                <i class="bi bi-check-circle me-2"></i>Lưu thay đổi
                            </button>
                            <a asp-action="Dashboard" class="btn btn-outline-secondary px-4 py-2 rounded-pill fw-medium">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}