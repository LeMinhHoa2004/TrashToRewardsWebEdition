@model TrashToRewardsV2.Models.ADMIN
@{
    ViewData["Title"] = "Thông tin Admin";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-lg-5 p-4">
                    <div class="d-flex align-items-center mb-4">
                        <i class="bi bi-person-badge-fill text-success me-3" style="font-size: 2rem;"></i>
                        <h2 class="mb-0 text-success fw-bold">Thông tin cá nhân (ADMIN)</h2>
                    </div>

                    <div class="bg-light p-4 rounded mb-4">
                        <div class="row mb-3">
                            <div class="col-sm-3 fw-bold text-success">
                                <i class="bi bi-person-fill me-2"></i>Họ tên:
                            </div>
                            <div class="col-sm-9">@Model.HoTenAD</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-sm-3 fw-bold text-success">
                                <i class="bi bi-envelope-fill me-2"></i>Email:
                            </div>
                            <div class="col-sm-9">@Model.EmailAD</div>
                        </div>
                        <div class="row">
                            <div class="col-sm-3 fw-bold text-success">
                                <i class="bi bi-telephone-fill me-2"></i>SĐT:
                            </div>
                            <div class="col-sm-9">@Model.SDTAD</div>
                        </div>
                    </div>

                    <div class="text-end">
                        <a href="/Admin/Dashboard" class="btn btn-success rounded-pill px-4">
                            <i class="bi bi-speedometer2 me-2"></i>Quay lại Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}