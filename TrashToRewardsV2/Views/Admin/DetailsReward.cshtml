@model TrashToRewardsV2.Models.PHANTHUONG

@{
    ViewData["Title"] = "Chi tiết phần thưởng";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-lg-5 p-4">
                    <div class="d-flex align-items-center mb-4">
                        <i class="bi bi-gift-fill text-success fs-1 me-3"></i>
                        <h2 class="fw-bold text-success mb-0">Chi tiết phần thưởng</h2>
                    </div>

                    <hr class="my-4">

                    <div class="row mb-4">
                        <div class="col-md-4">
                            @if (!string.IsNullOrEmpty(Model.HinhAnh))
                            {
                                <img src="~/images/@Model.HinhAnh" alt="@Model.TenQua" class="img-fluid rounded shadow-sm hover-zoom" />
                            }
                            else
                            {
                                <div class="p-5 bg-light rounded text-center">
                                    <i class="bi bi-image text-secondary" style="font-size: 5rem;"></i>
                                    <p class="mt-3">Chưa có hình ảnh</p>
                                </div>
                            }
                        </div>
                        <div class="col-md-8">
                            <div class="mb-3">
                                <strong><i class="bi bi-tag-fill text-success me-2"></i>Tên phần thưởng:</strong>
                                <span class="fs-5">@Model.TenQua</span>
                            </div>
                            <div class="mb-3">
                                <strong><i class="bi bi-file-text-fill text-success me-2"></i>Mô tả:</strong>
                                <p class="mt-2">@Model.MoTa</p>
                            </div>
                            <div class="mb-3">
                                <strong><i class="bi bi-star-fill text-success me-2"></i>Điểm đổi:</strong>
                                <span class="badge bg-success rounded-pill">@Model.DiemDoi điểm</span>
                            </div>
                            <div class="mb-3">
                                <strong><i class="bi bi-box-seam-fill text-success me-2"></i>Số lượng còn:</strong>
                                <span class="badge bg-primary rounded-pill">@Model.SoLuongCon</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5">
                        <h4 class="fw-bold text-success mb-4">
                            <i class="bi bi-geo-alt-fill me-2"></i>Số lượng tồn kho theo từng kho
                        </h4>

                        @if (Model.CTKHOQUAs != null && Model.CTKHOQUAs.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover border">
                                    <thead class="table-light">
                                        <tr>
                                            <th><i class="bi bi-building me-2"></i>Tên kho</th>
                                            <th><i class="bi bi-geo-alt me-2"></i>Địa chỉ</th>
                                            <th><i class="bi bi-calculator me-2"></i>Số lượng trong kho</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.CTKHOQUAs)
                                        {
                                            <tr>
                                                <td>@item.KHOQUA?.TenKQ</td>
                                                <td>@item.KHOQUA?.DiaChiKQ</td>
                                                <td>
                                                    <span class="badge bg-success rounded-pill">@item.SoLuongTrongKho</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle-fill me-2"></i>
                                Chưa có kho nào chứa phần thưởng này.
                            </div>
                        }
                    </div>

                    <div class="text-center mt-5">
                        <a asp-action="Dashboard" class="btn btn-outline-success rounded-pill px-4">
                            <i class="bi bi-arrow-left me-2"></i>Quay lại Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}