@model TrashToRewardsV2.Models.DONVITHUGOM
@{
    ViewData["Title"] = "Thêm đơn vị thu gom";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-lg-5 p-4">
                    <div class="mb-4 text-center">
                        <i class="bi bi-building-fill text-success fs-1"></i>
                        <h2 class="fw-bold text-success">Thêm đơn vị thu gom</h2>
                        <p class="text-muted">Tạo đơn vị thu gom phế liệu mới trong hệ thống</p>
                    </div>

                    <form asp-action="CreateUnit" method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                        }
                        <div class="mb-3">
                            <label asp-for="TenDV" class="form-label">Tên đơn vị</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-building"></i></span>
                                <input asp-for="TenDV" class="form-control" placeholder="Nhập tên đơn vị thu gom" required />
                            </div>
                            <span asp-validation-for="TenDV" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiaChiDV" class="form-label">Địa chỉ</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-geo-alt-fill"></i></span>
                                <input asp-for="DiaChiDV" class="form-control" placeholder="Nhập địa chỉ đầy đủ" required />
                            </div>
                            <span asp-validation-for="DiaChiDV" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SDTDV" class="form-label">Số điện thoại</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-telephone-fill"></i></span>
                                <input asp-for="SDTDV" class="form-control" placeholder="Nhập số điện thoại liên hệ" required />
                            </div>
                            <span asp-validation-for="SDTDV" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill">
                                <i class="bi bi-plus-circle-fill me-2"></i>Thêm đơn vị thu gom
                            </button>
                            <a asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại Dashboard
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Add animation on form elements
        document.addEventListener('DOMContentLoaded', function() {
            const formElements = document.querySelectorAll('.card, .form-control, .btn');
            formElements.forEach((element, index) => {
                setTimeout(() => {
                    element.classList.add('visible');
                }, 100 * index);
            });
        });
    </script>
}