@model TrashToRewardsV2.Models.NGUOIDUNG
@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-lg-5 p-4">
                    <div class="d-flex align-items-center mb-4">
                        <i class="bi bi-person-circle text-success fs-1 me-3"></i>
                        <h2 class="fw-bold text-success mb-0">Chi tiết người dùng</h2>
                    </div>

                    <hr class="my-4">

                    <div class="text-center mb-4">
                        <div class="avatar bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                            <i class="bi bi-person-fill text-success" style="font-size: 3rem;"></i>
                        </div>
                        <h3 class="fw-bold">@Model.HoTen</h3>
                        <div class="mb-3">
                            <span class="badge bg-success rounded-pill">
                                <i class="bi bi-star-fill me-1"></i>
                                @Model.DiemTichLuy điểm
                            </span>
                        </div>
                    </div>

                    <div class="bg-light p-4 rounded-3">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-envelope-fill text-success fs-4 me-3"></i>
                                    <div>
                                        <div class="text-muted small">Email</div>
                                        <div class="fw-semibold">@Model.Email</div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-telephone-fill text-success fs-4 me-3"></i>
                                    <div>
                                        <div class="text-muted small">Số điện thoại</div>
                                        <div class="fw-semibold">@Model.SDT</div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-geo-alt-fill text-success fs-4 me-3"></i>
                                    <div>
                                        <div class="text-muted small">Địa chỉ</div>
                                        <div class="fw-semibold">@Model.DiaChi</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-5">
                        <a asp-action="Dashboard" class="btn btn-outline-success rounded-pill px-4">
                            <i class="bi bi-arrow-left me-2"></i>Quay lại Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}