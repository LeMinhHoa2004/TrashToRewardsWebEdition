@* Dashboard.cshtml *@
@using Microsoft.EntityFrameworkCore
@using TrashToRewardsV2.Models

@model (IEnumerable<NGUOIDUNG> Users, IEnumerable<NHANVIEN> Staff)
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Dashboard Hero Section -->
<div class="bg-success text-white py-4 mb-4 rounded-3 shadow">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="fw-bold mb-2">Quản lý hệ thống</h1>
                <p class="lead mb-0">Kiểm soát và quản lý dữ liệu TrashToRewards</p>
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger mt-3 text-center fw-bold">
                        @TempData["Error"]
                    </div>
                }

            </div>
            <div class="col-md-4 text-md-end">
                <i class="bi bi-speedometer2 display-4"></i>
            </div>
        </div>
    </div>
</div>

<!-- Quick Action Cards -->
<div class="container mb-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-box-seam text-success fs-1 mb-3"></i>
                    <h3 class="card-title h4 text-success">Quản lý kho quà</h3>
                    <p class="card-text text-muted mb-4">Cập nhật và theo dõi tình trạng kho quà hiện tại</p>
                    <a asp-controller="KhoQua" asp-action="Index" class="btn btn-outline-success fw-bold rounded-pill px-4">
                        <i class="bi bi-box-arrow-right me-2"></i>Truy cập
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-truck text-success fs-1 mb-3"></i>
                    <h3 class="card-title h4 text-success">Quản lý nhân viên giao quà</h3>
                    <p class="card-text text-muted mb-4">Điều hành và phân công nhiệm vụ giao quà</p>
                    <a asp-controller="NhanVienGQ" asp-action="Index" class="btn btn-outline-success fw-bold rounded-pill px-4">
                        <i class="bi bi-box-arrow-right me-2"></i>Truy cập
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-bell text-success fs-1 mb-3"></i>
                    <h3 class="card-title h4 text-success">Quản lý thông báo</h3>
                    <p class="card-text text-muted mb-4">Gửi và quản lý thông báo đến người dùng và nhân viên</p>
                    <div class="d-flex flex-column gap-2">
                        <a asp-controller="AdminThongBao" asp-action="ThongBaoND" class="btn btn-outline-success fw-bold rounded-pill px-4">
                            <i class="bi bi-people me-2"></i>Người dùng
                        </a>
                        <a asp-controller="AdminThongBao" asp-action="ThongBaoNV" class="btn btn-outline-success fw-bold rounded-pill px-4">
                            <i class="bi bi-person-badge me-2"></i>Nhân viên
                        </a>
                        <a asp-controller="AdminThongBao" asp-action="ThongBaoNVGQ" class="btn btn-outline-success fw-bold rounded-pill px-4">
                            <i class="bi bi-truck me-2"></i>NV giao quà
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Users Management -->
<div class="container mb-5">
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-success text-white p-3">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 fw-bold">
                    <i class="bi bi-people-fill me-2"></i>Người dùng
                </h3>
                <a asp-action="CreateUser" class="btn btn-light text-success fw-bold rounded-pill">
                    <i class="bi bi-plus-circle me-2"></i>Thêm người dùng
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3">Mã ND</th>
                            <th class="py-3">Họ tên</th>
                            <th class="py-3">Email</th>
                            <th class="py-3">SĐT</th>
                            <th class="text-center py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td class="py-3">@user.MaND</td>
                                <td class="py-3">@user.HoTen</td>
                                <td class="py-3">@user.Email</td>
                                <td class="py-3">@user.SDT</td>
                                <td class="text-center py-3">
                                    <div class="btn-group">
                                        <a asp-action="EditUser" asp-route-id="@user.MaND" class="btn btn-sm btn-outline-warning me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="DeleteUser" asp-route-id="@user.MaND" class="btn btn-sm btn-outline-danger me-1">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                        <a asp-action="DetailsUser" asp-route-id="@user.MaND" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Staff Management -->
<div class="container mb-5">
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-success text-white p-3">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 fw-bold">
                    <i class="bi bi-person-badge-fill me-2"></i>Nhân viên
                </h3>
                <a asp-action="CreateStaff" class="btn btn-light text-success fw-bold rounded-pill">
                    <i class="bi bi-plus-circle me-2"></i>Thêm nhân viên
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3">Mã NV</th>
                            <th class="py-3">Họ tên</th>
                            <th class="py-3">Email</th>
                            <th class="py-3">Đơn vị</th>
                            <th class="text-center py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var staff in Model.Staff)
                        {
                            <tr>
                                <td class="py-3">@staff.MaNV</td>
                                <td class="py-3">@staff.HoTenNV</td>
                                <td class="py-3">@staff.EmailNV</td>
                                <td class="py-3">@staff.DONVITHUGOM?.TenDV</td>
                                <td class="text-center py-3">
                                    <div class="btn-group">
                                        <a asp-action="EditStaff" asp-route-id="@staff.MaNV" class="btn btn-sm btn-outline-warning me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="DeleteStaff" asp-route-id="@staff.MaNV" class="btn btn-sm btn-outline-danger me-1">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                        <a asp-action="DetailsStaff" asp-route-id="@staff.MaNV" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Collection Units Management -->
<div class="container mb-5">
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-success text-white p-3">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 fw-bold">
                    <i class="bi bi-building me-2"></i>Đơn vị thu gom
                </h3>
                <a asp-action="CreateUnit" class="btn btn-light text-success fw-bold rounded-pill">
                    <i class="bi bi-plus-circle me-2"></i>Thêm đơn vị
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3">Mã DV</th>
                            <th class="py-3">Tên đơn vị</th>
                            <th class="py-3">Địa chỉ</th>
                            <th class="py-3">SĐT</th>
                            <th class="text-center py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in await Context.RequestServices.GetRequiredService<ApplicationDbContext>().DONVITHUGOM.ToListAsync())
                        {
                            <tr>
                                <td class="py-3">@unit.MaDV</td>
                                <td class="py-3">@unit.TenDV</td>
                                <td class="py-3">@unit.DiaChiDV</td>
                                <td class="py-3">@unit.SDTDV</td>
                                <td class="text-center py-3">
                                    <div class="btn-group">
                                        <a asp-action="EditUnit" asp-route-id="@unit.MaDV" class="btn btn-sm btn-outline-warning me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="DeleteUnit" asp-route-id="@unit.MaDV" class="btn btn-sm btn-outline-danger me-1">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                        <a asp-action="DetailsUnit" asp-route-id="@unit.MaDV" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Scrap Types Management -->
<div class="container mb-5">
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-success text-white p-3">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 fw-bold">
                    <i class="bi bi-recycle me-2"></i>Loại phế liệu
                </h3>
                <a asp-action="CreateScrapType" class="btn btn-light text-success fw-bold rounded-pill">
                    <i class="bi bi-plus-circle me-2"></i>Thêm loại phế liệu
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3">Mã PL</th>
                            <th class="py-3">Tên loại</th>
                            <th class="py-3">Đơn vị</th>
                            <th class="py-3">Tỉ lệ điểm</th>
                            <th class="text-center py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var scrap in await Context.RequestServices.GetRequiredService<ApplicationDbContext>().LOAIPHELIEU.ToListAsync())
                        {
                            <tr>
                                <td class="py-3">@scrap.MaLoaiPL</td>
                                <td class="py-3">@scrap.TenLoai</td>
                                <td class="py-3">@scrap.DonVi</td>
                                <td class="py-3">@scrap.TiLeDiem</td>
                                <td class="text-center py-3">
                                    <div class="btn-group">
                                        <a asp-action="EditScrapType" asp-route-id="@scrap.MaLoaiPL" class="btn btn-sm btn-outline-warning me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="DeleteScrapType" asp-route-id="@scrap.MaLoaiPL" class="btn btn-sm btn-outline-danger me-1">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                        <a asp-action="DetailsScrapType" asp-route-id="@scrap.MaLoaiPL" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Rewards Management -->
<div class="container mb-5">
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-success text-white p-3">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 fw-bold">
                    <i class="bi bi-gift me-2"></i>Phần thưởng
                </h3>
                <a asp-action="CreateReward" class="btn btn-light text-success fw-bold rounded-pill">
                    <i class="bi bi-plus-circle me-2"></i>Thêm phần thưởng
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3">Mã PT</th>
                            <th class="py-3">Hình ảnh</th>
                            <th class="py-3">Tên phần thưởng</th>
                            <th class="py-3">Điểm yêu cầu</th>
                            <th class="py-3">Số lượng</th>
                            <th class="text-center py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reward in await Context.RequestServices
                        .GetRequiredService<ApplicationDbContext>()
                        .PHANTHUONG.ToListAsync())
                        {
                            <tr>
                                <td class="py-3">@reward.MaQua</td>
                                <td class="py-3">
                                    @if (!string.IsNullOrEmpty(reward.HinhAnh))
                                    {
                                        <img src="~/images/@reward.HinhAnh" alt="@reward.TenQua" class="img-thumbnail rounded" style="max-height: 50px;" />
                                    }
                                </td>
                                <td class="py-3">@reward.TenQua</td>
                                <td class="py-3">@reward.DiemDoi</td>
                                <td class="py-3">@reward.SoLuongCon</td>
                                <td class="text-center py-3">
                                    <div class="btn-group">
                                        <a asp-action="EditReward" asp-route-id="@reward.MaQua" class="btn btn-sm btn-outline-warning me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="DeleteReward" asp-route-id="@reward.MaQua" class="btn btn-sm btn-outline-danger me-1">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                        <a asp-action="DetailsReward" asp-route-id="@reward.MaQua" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Admin Management -->
<div class="container mb-5">
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-success text-white p-3">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 fw-bold">
                    <i class="bi bi-shield-lock me-2"></i>Quản trị viên (Admin)
                </h3>
                <a asp-action="CreateAdmin" class="btn btn-light text-success fw-bold rounded-pill">
                    <i class="bi bi-plus-circle me-2"></i>Thêm admin
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3">Mã Admin</th>
                            <th class="py-3">Họ tên</th>
                            <th class="py-3">SDT</th>
                            <th class="py-3">Email</th>
                            <th class="text-center py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var admin in await Context.RequestServices.GetRequiredService<ApplicationDbContext>().ADMIN.ToListAsync())
                        {
                            <tr>
                                <td class="py-3">@admin.MaAD</td>
                                <td class="py-3">@admin.HoTenAD</td>
                                <td class="py-3">@admin.SDTAD</td>
                                <td class="py-3">@admin.EmailAD</td>
                                <td class="text-center py-3">
                                    <div class="btn-group">
                                        <a asp-action="EditAdmin" asp-route-id="@admin.MaAD" class="btn btn-sm btn-outline-warning me-1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="DeleteAdmin" asp-route-id="@admin.MaAD" class="btn btn-sm btn-outline-danger me-1">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                        <a asp-action="DetailsAdmin" asp-route-id="@admin.MaAD" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add hover effect to rows
        document.querySelectorAll('tbody tr').forEach(row => {
            row.addEventListener('mouseover', function() {
                this.classList.add('bg-light');
            });
            row.addEventListener('mouseout', function() {
                this.classList.remove('bg-light');
            });
        });
    </script>
}