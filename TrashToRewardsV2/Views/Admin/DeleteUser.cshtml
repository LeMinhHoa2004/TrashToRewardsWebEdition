@model TrashToRewardsV2.Models.NGUOIDUNG
@{
    ViewData["Title"] = "Xóa người dùng";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded">
                <div class="card-body p-lg-5 p-4">
                    <h2 class="fw-bold text-success mb-4">Xác nhận xóa người dùng</h2>

                    <div class="mb-4 text-center p-4 bg-light rounded hover-card">
                        <i class="bi bi-person-circle text-success fs-1 mb-3"></i>
                        <h4 class="fw-bold">@Model.HoTen</h4>
                    </div>

                    <div class="alert alert-danger rounded mb-4">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        Bạn có chắc chắn muốn xóa người dùng <strong>@Model.HoTen</strong> không?
                    </div>

                    <form asp-action="DeleteUserConfirmed" method="post">
                        <input type="hidden" asp-for="MaND" />
                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-danger px-4 rounded-pill">
                                <i class="bi bi-trash-fill me-2"></i>Xóa
                            </button>
                            <a asp-action="Dashboard" class="btn btn-outline-secondary px-4 rounded-pill">
                                <i class="bi bi-x-circle me-2"></i>Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}