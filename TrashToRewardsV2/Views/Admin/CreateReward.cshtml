@model TrashToRewardsV2.Models.PHANTHUONG

@{
    ViewData["Title"] = "Thêm phần thưởng";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-lg-5 p-4">
                    <div class="mb-4 text-center">
                        <i class="bi bi-gift-fill text-success fs-1"></i>
                        <h2 class="fw-bold text-success">Thêm phần thưởng</h2>
                        <p class="text-muted">Tạo phần thưởng mới để người dùng có thể đổi điểm</p>
                    </div>

                    <form asp-action="CreateReward" method="post" enctype="multipart/form-data">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                        }
                        <div class="row">
                            <!-- Form nhập liệu -->
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label asp-for="TenQua" class="form-label">Tên phần thưởng</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-tag-fill"></i></span>
                                        <input asp-for="TenQua" class="form-control" placeholder="Nhập tên phần thưởng" />
                                    </div>
                                    <span asp-validation-for="TenQua" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="MoTa" class="form-label">Mô tả</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-card-text"></i></span>
                                        <textarea asp-for="MoTa" class="form-control" rows="4" placeholder="Mô tả chi tiết về phần thưởng"></textarea>
                                    </div>
                                    <span asp-validation-for="MoTa" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="DiemDoi" class="form-label">Điểm đổi</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-coin"></i></span>
                                        <input asp-for="DiemDoi" class="form-control" placeholder="Nhập số điểm cần để đổi" />
                                    </div>
                                    <span asp-validation-for="DiemDoi" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Hình ảnh phần thưởng</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-image"></i></span>
                                        <input type="file" id="hinhAnhInput" name="hinhAnh" class="form-control" accept="image/*" onchange="previewImage(this)" required />
                                    </div>
                                    <span class="text-danger" id="hinhAnhError"></span>
                                    <small class="form-text text-muted">Chỉ chấp nhận file ảnh (jpg, png, gif,...)</small>
                                </div>
                            </div>

                            <!-- Xem trước hình ảnh -->
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Xem trước hình ảnh</label>
                                    <div class="border rounded p-2 text-center" style="min-height: 200px; background-color: #f8f9fa;">
                                        <img id="imagePreview" src="" alt="Xem trước" class="img-fluid d-none" />
                                        <div id="noImageMessage" class="text-muted py-5">
                                            <i class="bi bi-image text-secondary" style="font-size: 3rem;"></i>
                                            <p class="mt-3">Chưa có hình ảnh</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Nút hành động -->
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill">
                                <i class="bi bi-plus-circle-fill me-2"></i>Thêm phần thưởng
                            </button>
                            <a asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại Dashboard
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewImage(input) {
            var preview = document.getElementById('imagePreview');
            var noImageMessage = document.getElementById('noImageMessage');

            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                    noImageMessage.classList.add('d-none');
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.src = '';
                preview.classList.add('d-none');
                noImageMessage.classList.remove('d-none');
            }
        }
        // Kiểm tra hình ảnh khi submit
        document.querySelector('form').addEventListener('submit', function (e) {
            const fileInput = document.getElementById('hinhAnhInput');
            const errorMsg = document.getElementById('hinhAnhError');

            if (!fileInput.files || fileInput.files.length === 0) {
                e.preventDefault(); // Ngăn form submit
                errorMsg.textContent = 'Vui lòng chọn hình ảnh cho phần thưởng';
            } else {
                errorMsg.textContent = '';
            }
        });

        // Add animation on form elements
        document.addEventListener('DOMContentLoaded', function() {
            const formElements = document.querySelectorAll('.card, .form-control, .btn');
            formElements.forEach((element, index) => {
                setTimeout(() => {
                    element.classList.add('visible');
                }, 100 * index);
            });
        });
    </script>
}