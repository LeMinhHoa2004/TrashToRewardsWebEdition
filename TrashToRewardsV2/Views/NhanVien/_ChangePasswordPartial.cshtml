@model TrashToRewardsV2.ViewModels.ChangePasswordViewModel

<form asp-action="ChangePassword" method="post" class="card border-0 shadow-lg">
    <div class="card-body p-lg-5 p-4">
        <div class="d-flex align-items-center mb-4">
            <i class="bi bi-key-fill text-success me-3" style="font-size: 2rem;"></i>
            <h3 class="mb-0 text-success fw-bold">Đổi mật khẩu</h3>
        </div>
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
        }
        

        <div class="bg-light p-4 rounded mb-4">
            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label fw-bold text-success">
                    <i class="bi bi-lock-fill me-2"></i>Mật khẩu hiện tại
                </label>
                <input asp-for="CurrentPassword" class="form-control border-0 shadow-sm" type="password" placeholder="Nhập mật khẩu hiện tại" />
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label fw-bold text-success">
                    <i class="bi bi-shield-lock-fill me-2"></i>Mật khẩu mới
                </label>
                <input asp-for="NewPassword" class="form-control border-0 shadow-sm" type="password" placeholder="Nhập mật khẩu mới" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label fw-bold text-success">
                    <i class="bi bi-check-circle-fill me-2"></i>Xác nhận mật khẩu
                </label>
                <input asp-for="ConfirmPassword" class="form-control border-0 shadow-sm" type="password" placeholder="Nhập lại mật khẩu mới" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-success btn-lg rounded-pill px-4">
                <i class="bi bi-save-fill me-2"></i>Đổi mật khẩu
            </button>
        </div>
    </div>
</form>