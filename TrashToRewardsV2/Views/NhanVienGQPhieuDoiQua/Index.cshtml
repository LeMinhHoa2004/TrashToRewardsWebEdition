@model IEnumerable<TrashToRewardsV2.Models.PHIEUDOIQUA>

@{
    ViewData["Title"] = "Quản lý Phiếu Đổi Quà";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-gift-fill me-2"></i>Phiếu Đổi Quà - Kho của bạn
                    </h4>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="py-3">Mã Phiếu</th>
                                    <th class="py-3">Người dùng</th>
                                    <th class="py-3">Điểm dùng</th>
                                    <th class="py-3">Trạng thái</th>
                                    <th class="py-3">Hình thức</th>
                                    <th class="py-3 text-center">Xử lý</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model)
                                {
                                    <tr>
                                        <td class="align-middle">
                                            <span class="badge bg-primary rounded-pill">@p.MaPDQ</span>
                                        </td>
                                        <td class="align-middle">
                                            <i class="bi bi-person-fill me-1 text-success"></i> @p.NGUOIDUNG.HoTen
                                        </td>
                                        <td class="align-middle">
                                            <span class="badge bg-success rounded-pill">@p.SoDiemSuDung điểm</span>
                                        </td>
                                        <td class="align-middle">
                                            @switch (p.TrangThai)
                                            {
                                                case "ChuaXacNhan":
                                                    <span class="badge bg-warning rounded-pill">Chưa xác nhận</span>
                                                    break;
                                                case "DaXacNhan":
                                                    <span class="badge bg-primary rounded-pill">Đã xác nhận</span>
                                                    break;
                                                case "DangGiao":
                                                    <span class="badge bg-info rounded-pill">Đang giao</span>
                                                    break;
                                                case "DaGiao":
                                                    <span class="badge bg-success rounded-pill">Đã giao</span>
                                                    break;
                                                case "ChuaNhan":
                                                    <span class="badge bg-secondary rounded-pill">Đã xác nhận - Chưa nhận</span>
                                                    break;
                                                case "DaNhan":
                                                    <span class="badge bg-success rounded-pill">Đã nhận</span>
                                                    break;
                                                case "DaHuy":
                                                    <span class="badge bg-danger rounded-pill">Đã hủy</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-light text-dark rounded-pill">Không xác định</span>
                                                    break;
                                            }

                                        </td>
                                        <td class="align-middle">
                                            @if (p.HinhThucNhanQua == "TaiNha")
                                            {
                                                <i class="bi bi-house-door me-1"></i> <span>Tại nhà</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-shop me-1"></i> <span>Trực tiếp</span>
                                            }
                                        </td>
                                        <td class="align-middle text-center">
                                            <a asp-action="Details" asp-route-id="@p.MaPDQ" class="btn btn-outline-success btn-sm rounded-pill">
                                                <i class="bi bi-info-circle me-1"></i> Chi tiết
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="text-center p-5">
                            <i class="bi bi-inbox text-muted" style="font-size: 64px;"></i>
                            <p class="text-muted mt-3">Không có phiếu đổi quà nào</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>