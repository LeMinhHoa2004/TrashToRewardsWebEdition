@model TrashToRewardsV2.ViewModels.PhieuThuGomViewModel
@using TrashToRewardsV2.Models

@{
    ViewData["Title"] = "Chi tiết phiếu thu gom";
    var phieu = Model.PhieuThuGom;
    var chiTietList = Model.ChiTietPhieuThuGom;
}

<div class="container py-5">
    <div class="bg-white bg-opacity-75 rounded shadow p-4 mb-4">
        <h2 class="page-title fw-bold text-success">Chi tiết phiếu thu gom</h2>
        <p class="text-muted lead">Thông tin chi tiết về phiếu thu gom và phế liệu đã nhận</p>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="card border-0 shadow-sm hover-card mb-4 visible">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Thông tin phiếu</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-hash fs-4 text-success me-3"></i>
                                <div>
                                    <div class="text-muted small">Mã phiếu</div>
                                    <div class="fw-bold">@phieu.MaPhieu</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-person fs-4 text-success me-3"></i>
                                <div>
                                    <div class="text-muted small">Khách hàng</div>
                                    <div class="fw-bold">@phieu.XACNHAN?.PHIEUDATLICH?.NGUOIDUNG?.HoTen</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-house fs-4 text-success me-3"></i>
                                <div>
                                    <div class="text-muted small">Địa chỉ</div>
                                    <div class="fw-bold">@phieu.XACNHAN?.PHIEUDATLICH?.NGUOIDUNG?.DiaChi</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-calendar-date fs-4 text-success me-3"></i>
                                <div>
                                    <div class="text-muted small">Ngày thu gom</div>
                                    <div class="fw-bold">@phieu.XACNHAN?.PHIEUDATLICH?.NgayDL.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-geo-alt fs-4 text-success me-3"></i>
                                <div>
                                    <div class="text-muted small">Địa điểm thu gom</div>
                                    <div class="fw-bold">@phieu.XACNHAN?.PHIEUDATLICH?.DiaDiemDL</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-check-circle fs-4 text-success me-3"></i>
                                <div>
                                    <div class="text-muted small">Nhân viên xác nhận</div>
                                    <div class="fw-bold">@phieu.XACNHAN?.NHANVIEN?.HoTenNV</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-person-badge fs-4 text-success me-3"></i>
                                <div>
                                    <div class="text-muted small">Nhân viên thực hiện</div>
                                    <div class="fw-bold">@phieu.NHANVIEN?.HoTenNV</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-award fs-4 text-success me-3"></i>
                                <div>
                                    <div class="text-muted small">Tổng điểm</div>
                                    <div class="fs-4 fw-bold text-success">@phieu.TongDiem</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm hover-card mb-4 visible">
        <div class="card-header bg-success text-white py-3">
            <h5 class="mb-0"><i class="bi bi-recycle me-2"></i>Chi tiết phế liệu thu gom</h5>
        </div>
        <div class="card-body p-4">
            @if (chiTietList != null && chiTietList.Any())
            {
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Loại phế liệu</th>
                                <th>Khối lượng</th>
                                <th>Điểm nhận được</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in chiTietList)
                            {
                                <tr class="hover-card-row visible">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-recycle text-success me-2"></i>
                                            <span>@item.LOAIPHELIEU?.TenLoai</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-speedometer2 text-success me-2"></i>
                                            <span><strong>@item.KhoiLuong</strong> @item.LOAIPHELIEU?.DonVi</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-success">@item.SoDiemNhanDuoc</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="2" class="text-end fw-bold">Tổng điểm:</td>
                                <td><span class="badge bg-success fs-5">@phieu.TongDiem</span></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <p>Không có dữ liệu chi tiết phế liệu nào.</p>
                </div>
            }

            <div class="mt-4 text-center">
                <a asp-action="Index" class="btn btn-success btn-lg px-4 rounded-pill">
                    <i class="bi bi-arrow-left-circle me-2"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add animation on page load
        document.addEventListener('DOMContentLoaded', function() {
            const cards = document.querySelectorAll('.card');
            const rows = document.querySelectorAll('.hover-card-row');

            // Animate cards with delay
            cards.forEach((card, index) => {
                setTimeout(() => {
                    card.classList.add('visible');
                }, 100 * index);
            });

            // Animate table rows with delay
            rows.forEach((row, index) => {
                setTimeout(() => {
                    row.classList.add('visible');
                }, 150 * (index + 1));
            });
        });
    </script>
}