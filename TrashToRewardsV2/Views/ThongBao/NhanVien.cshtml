@model IEnumerable<TrashToRewardsV2.Models.THONGBAONV>

@{
    ViewData["Title"] = "Thông báo của tôi";
}

<!-- Page Header -->
<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <h2 class="page-title fw-bold text-success">Thông báo của tôi</h2>
            <p class="lead text-muted">Quản lý thông báo hệ thống dành cho nhân viên</p>
        </div>
    </div>
</div>

<div class="container">
    <div class="card border-0 shadow-lg mb-5">
        <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
            <h6 class="m-0 fw-bold text-success">Danh sách thông báo</h6>
            <button id="btnDanhDauTatCaNV" class="btn btn-success btn-sm rounded-pill px-3">
                <i class="bi bi-check-all me-1"></i>Đánh dấu tất cả đã đọc
            </button>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="list-group list-group-flush" id="notificationListNV">
                    @foreach (var item in Model)
                    {
                        <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-start border-bottom @(item.DaDoc ? "" : "fw-bold")" data-id="@item.MaTBNV">
                            <div class="py-2">
                                <div class="d-flex w-100 justify-content-between">
                                    <h5 class="mb-1 @(item.DaDoc ? "text-dark" : "text-success")">Thông báo từ hệ thống</h5>
                                    <small class="text-muted">@item.NgayTaoNV.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                                <p class="mb-1">@item.NoiDungNV</p>
                                @if (!item.DaDoc)
                                {
                                    <span class="badge bg-warning text-dark rounded-pill">Chưa đọc</span>
                                }
                            </div>
                            @if (!item.DaDoc)
                            {
                                <button class="btn btn-sm btn-outline-success rounded-circle btn-danh-dau-doc-nv" data-id="@item.MaTBNV" title="Đánh dấu là đã đọc">
                                    <i class="bi bi-check"></i>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state py-5">
                    <i class="bi bi-bell text-success mb-3"></i>
                    <p class="text-muted">Bạn không có thông báo nào.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Đánh dấu tất cả đã đọc
        document.getElementById("btnDanhDauTatCaNV")?.addEventListener("click", async function () {
            const response = await fetch("/ThongBao/DanhDauTatCaDaDocNV", { method: "POST" });
            if (response.ok) {
                document.querySelectorAll("#notificationListNV .list-group-item").forEach(item => {
                    item.classList.remove("fw-bold");
                    item.querySelector("h5").classList.remove("text-success");
                    item.querySelector("h5").classList.add("text-dark");
                    item.querySelector(".badge")?.remove();
                    item.querySelector(".btn-danh-dau-doc-nv")?.remove();
                });
            }
        });

        // Đánh dấu từng thông báo đã đọc
        document.querySelectorAll(".btn-danh-dau-doc-nv").forEach(button => {
            button.addEventListener("click", async function () {
                const id = this.getAttribute("data-id");
                const response = await fetch(`/api/ThongBaoAPI/DanhDauDaDocNV/${id}`, { method: "POST" });
                if (response.ok) {
                    const item = this.closest(".list-group-item");
                    item.classList.remove("fw-bold");
                    item.querySelector("h5").classList.remove("text-success");
                    item.querySelector("h5").classList.add("text-dark");
                    item.querySelector(".badge")?.remove();
                    this.remove(); // xóa nút ✔ sau khi đã đánh dấu
                }
            });
        });

        // Add animation on scroll
        window.addEventListener('scroll', function() {
            const elements = document.querySelectorAll('.card, .list-group-item');

            elements.forEach(element => {
                const position = element.getBoundingClientRect();

                // If element is in viewport
                if (position.top < window.innerHeight && position.bottom >= 0) {
                    element.classList.add('visible');
                }
            });
        });
    </script>
}