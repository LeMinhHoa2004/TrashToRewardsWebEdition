@model TrashToRewardsV2.Models.CTKHOQUA
@{
    ViewData["Title"] = "Sửa phần thưởng trong kho";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg hover-card">
                <div class="card-header bg-primary text-white py-3">
                    <h3 class="card-title mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Sửa số lượng phần thưởng trong kho
                    </h3>
                </div>
                <div class="card-body p-lg-5 p-4">
                    <form asp-action="EditCTKhoQua" method="post">
                        @Html.AntiForgeryToken()
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                        }
                        <input type="hidden" asp-for="MaKQ" />
                        <input type="hidden" asp-for="MaQua" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Phần thưởng</label>
                            <input type="text" class="form-control bg-light" value="@Model.PHANTHUONG?.TenQua" readonly />
                        </div>

                        <div class="mb-4">
                            <label asp-for="SoLuongTrongKho" class="form-label fw-semibold">Số lượng trong kho</label>
                            <div class="input-group">
                                <span class="input-group-text bg-primary text-white">
                                    <i class="bi bi-123"></i>
                                </span>
                                <input asp-for="SoLuongTrongKho" type="number" min="0" class="form-control" placeholder="Nhập số lượng" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Details" asp-route-id="@Model.MaKQ" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5">
                                <i class="bi bi-check-circle me-2"></i>Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>