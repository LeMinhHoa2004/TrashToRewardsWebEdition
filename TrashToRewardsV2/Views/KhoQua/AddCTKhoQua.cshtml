@model TrashToRewardsV2.Models.CTKHOQUA
@{
    ViewData["Title"] = "Thêm phần thưởng vào Kho";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg hover-card">
                <div class="card-header bg-success text-white py-3">
                    <h3 class="card-title mb-0">
                        <i class="bi bi-gift me-2"></i>Thêm phần thưởng vào Kho
                    </h3>
                </div>
                <div class="card-body p-lg-5 p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <form asp-action="AddCTKhoQua" method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                        }
                        <input type="hidden" asp-for="MaKQ" />

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Chọn phần thưởng</label>
                            <div class="input-group">
                                <span class="input-group-text bg-success text-white">
                                    <i class="bi bi-gift"></i>
                                </span>
                                <select asp-for="MaQua" class="form-select" asp-items="ViewBag.ListPhanThuong">
                                    <option value="" disabled selected>-- Chọn phần thưởng --</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="SoLuongTrongKho" class="form-label fw-semibold">Số lượng trong kho</label>
                            <div class="input-group">
                                <span class="input-group-text bg-success text-white">
                                    <i class="bi bi-123"></i>
                                </span>
                                <input asp-for="SoLuongTrongKho" type="number" min="1" class="form-control" placeholder="Nhập số lượng" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Details" asp-route-id="@Model.MaKQ" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại
                            </a>
                            <button type="submit" class="btn btn-success rounded-pill px-5">
                                <i class="bi bi-check-circle me-2"></i>Lưu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>