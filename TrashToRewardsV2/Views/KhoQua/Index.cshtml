@model IEnumerable<TrashToRewardsV2.Models.KHOQUA>
@{
    ViewData["Title"] = "Danh sách Kho Quà";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold text-success">Danh sách Kho Quà</h2>
            <p class="text-muted">Quản lý tất cả các kho quà trong hệ thống</p>
        </div>
        <div class="col-md-4 text-md-end d-flex align-items-center justify-content-md-end">
            <a asp-action="Create" class="btn btn-success rounded-pill px-4">
                <i class="bi bi-plus-circle me-2"></i>Thêm Kho Quà
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm hover-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-success text-white">
                        <tr>
                            <th class="ps-3">Tên kho</th>
                            <th>Địa chỉ</th>
                            <th>SĐT</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kho in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <strong>@kho.TenKQ</strong>
                                </td>
                                <td>
                                    <i class="bi bi-geo-alt-fill text-success me-1"></i>
                                    @kho.DiaChiKQ
                                </td>
                                <td>
                                    <i class="bi bi-telephone-fill text-success me-1"></i>
                                    @kho.SDTKQ
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@kho.MaKQ" class="btn btn-outline-success btn-sm rounded-pill me-1">
                                        <i class="bi bi-info-circle"></i> Chi tiết
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@kho.MaKQ" class="btn btn-outline-primary btn-sm rounded-pill me-1">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@kho.MaKQ" class="btn btn-outline-danger btn-sm rounded-pill">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>