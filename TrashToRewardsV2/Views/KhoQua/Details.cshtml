@model TrashToRewardsV2.Models.KHOQUA

@{
    ViewData["Title"] = "Chi tiết Kho Quà";
}

<div class="container py-4">
    @* <div class="row"> *@
    @*     <div class="col-12"> *@
    @*         <nav aria-label="breadcrumb"> *@
    @*             <ol class="breadcrumb"> *@
    @*                 <li class="breadcrumb-item"><a href="#">Kho quà</a></li> *@
    @*                 <li class="breadcrumb-item active">Chi tiết</li> *@
    @*             </ol> *@
    @*         </nav> *@
    @*     </div> *@
    @* </div> *@

    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold text-success">
                <i class="bi bi-shop me-2"></i>@Model.TenKQ
            </h2>
        </div>
        <div class="col-md-4 text-md-end">
            <a asp-action="Edit" asp-route-id="@Model.MaKQ" class="btn btn-primary rounded-pill px-4 me-2">
                <i class="bi bi-pencil me-2"></i>Sửa
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-list me-2"></i>Danh sách
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm hover-card">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Thông tin kho quà</h5>
                    <hr />
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-success text-white rounded-circle p-2 me-3">
                            <i class="bi bi-geo-alt"></i>
                        </div>
                        <div>
                            <p class="mb-0 fw-semibold">Địa chỉ</p>
                            <p class="text-muted">@Model.DiaChiKQ</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="bg-success text-white rounded-circle p-2 me-3">
                            <i class="bi bi-telephone"></i>
                        </div>
                        <div>
                            <p class="mb-0 fw-semibold">Số điện thoại</p>
                            <p class="text-muted">@Model.SDTKQ</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm hover-card">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Chi tiết Phần Thưởng trong Kho</h5>
                    <a asp-action="AddCTKhoQua" asp-route-khoId="@Model.MaKQ" class="btn btn-light btn-sm rounded-pill">
                        <i class="bi bi-plus-circle me-1"></i>Thêm Phần Thưởng
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead>
                                <tr class="bg-light">
                                    <th class="ps-3">Tên phần thưởng</th>
                                    <th>Số lượng trong kho</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ct in Model.CTKHOQUAs)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <i class="bi bi-gift text-success me-2"></i>
                                            <strong>@ct.PHANTHUONG?.TenQua</strong>
                                        </td>
                                        <td>
                                            <span class="badge bg-success rounded-pill">@ct.SoLuongTrongKho</span>
                                        </td>
                                        <td class="text-center">
                                            <a asp-action="EditCTKhoQua" asp-route-maKQ="@ct.MaKQ" asp-route-maQua="@ct.MaQua" class="btn btn-outline-primary btn-sm rounded-pill me-1">
                                                <i class="bi bi-pencil"></i> Sửa
                                            </a>
                                            <a asp-action="DeleteCTKhoQua" asp-route-maKQ="@ct.MaKQ" asp-route-maQua="@ct.MaQua" class="btn btn-outline-danger btn-sm rounded-pill">
                                                <i class="bi bi-trash"></i> Xóa
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>