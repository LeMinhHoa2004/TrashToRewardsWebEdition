@model TrashToRewardsV2.Models.KHOQUA
@{
    ViewData["Title"] = "Sửa Kho Quà";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg hover-card">
                <div class="card-header bg-primary text-white py-3">
                    <h3 class="card-title mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Sửa Kho Quà
                    </h3>
                </div>
                <div class="card-body p-lg-5 p-4">
                    <form asp-action="Edit" method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                        }
                        <input type="hidden" asp-for="MaKQ" />

                        <div class="mb-4">
                            <label asp-for="TenKQ" class="form-label fw-semibold">Tên kho quà</label>
                            <div class="input-group">
                                <span class="input-group-text bg-primary text-white">
                                    <i class="bi bi-shop"></i>
                                </span>
                                <input asp-for="TenKQ" class="form-control" placeholder="Nhập tên kho quà" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DiaChiKQ" class="form-label fw-semibold">Địa chỉ</label>
                            <div class="input-group">
                                <span class="input-group-text bg-primary text-white">
                                    <i class="bi bi-geo-alt"></i>
                                </span>
                                <input asp-for="DiaChiKQ" class="form-control" placeholder="Nhập địa chỉ kho quà" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="SDTKQ" class="form-label fw-semibold">Số điện thoại</label>
                            <div class="input-group">
                                <span class="input-group-text bg-primary text-white">
                                    <i class="bi bi-telephone"></i>
                                </span>
                                <input asp-for="SDTKQ" class="form-control" placeholder="Nhập số điện thoại" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5">
                                <i class="bi bi-check-circle me-2"></i>Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>