@model IEnumerable<TrashToRewardsV2.Models.LOAIPHELIEU>

@{
    ViewData["Title"] = "Danh sách Loại Phế Liệu";
}

<div class="container py-5">
    <div class="bg-white bg-opacity-75 rounded p-4 mb-4">
        <div class="row mb-3">
            <div class="col-md-8">
                <h2 class="fw-bold text-success mb-3">Danh sách Loại Phế Liệu</h2>
                <p class="lead text-muted">Các loại phế liệu được thu gom và quy đổi điểm thưởng</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            string icon = "bi-box-seam";
            if (item.TenLoai.ToLower().Contains("nhựa")) { icon = "bi-cup-straw"; }
            else if (item.TenLoai.ToLower().Contains("giấy")) { icon = "bi-newspaper"; }
            else if (item.TenLoai.ToLower().Contains("pin") || item.TenLoai.ToLower().Contains("điện")) { icon = "bi-battery-charging"; }
            else if (item.TenLoai.ToLower().Contains("kim loại") || item.TenLoai.ToLower().Contains("nhôm")) { icon = "bi-box-seam"; }
            else if (item.TenLoai.ToLower().Contains("thủy tinh")) { icon = "bi-cup-hot"; }
            else { icon = "bi-trash"; }

            <div class="col-md-4 col-lg-4 mb-4">
                <div class="card border-0 shadow-sm hover-card h-100">
                    <div class="card-body p-4">
                        <div class="text-center mb-3">
                            <div class="bg-success bg-opacity-10 p-3 rounded-circle d-inline-block mb-3">
                                <i class="bi @icon text-success fs-1"></i>
                            </div>
                            <h4 class="card-title fw-bold text-success">@item.TenLoai</h4>
                        </div>
                        <div class="row mb-3 g-2">
                            <div class="col-6">
                                <div class="p-3 bg-light rounded">
                                    <h6 class="text-muted mb-1 small">Đơn vị:</h6>
                                    <h6 class="mb-0">@item.DonVi</h6>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-light rounded">
                                    <h6 class="text-muted mb-1 small">Điểm:</h6>
                                    <h6 class="mb-0 text-success fw-bold">@item.TiLeDiem</h6>
                                </div>
                            </div>
                        </div>
                        <div class="text-center mt-3">
                            <a asp-action="Details" asp-route-id="@item.MaLoaiPL" class="btn btn-outline-success rounded-pill px-4">
                                <i class="bi bi-info-circle me-2"></i> Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>