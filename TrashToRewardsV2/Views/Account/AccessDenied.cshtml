@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-danger rounded-4">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="bi bi-shield-lock-fill text-danger" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="text-danger mb-3">403 - Không có quyền truy cập</h2>
                    <p class="text-muted mb-4">Bạn không có đủ quyền để truy cập vào trang này.<br />Vui lòng đăng nhập bằng tài khoản có quyền phù hợp.</p>
                    <a href="/" class="btn btn-outline-primary px-4 rounded-pill">
                        <i class="bi bi-house-door-fill me-2"></i> Quay về trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
