@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-lg-5 p-4">
                    <h2 class="text-center text-success fw-bold mb-4">Quên mật khẩu</h2>

                    <form asp-action="ForgotPassword" method="post">
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">@ViewBag.Error</div>
                        }

                        <div class="mb-4">
                            <div class="form-floating">
                                <input type="email" name="email" class="form-control" id="emailInput" placeholder="Nhập email đăng ký" required />
                                <label for="emailInput">Email</label>
                            </div>
                            <div class="form-text text-muted mt-2">
                                <i class="bi bi-info-circle me-1"></i> Mã OTP sẽ được gửi đến email này
                            </div>
                        </div>

                        <div class="d-grid mb-4">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold">Gửi mã OTP</button>
                        </div>
                    </form>

                    <div class="text-center mt-3">
                        <p class="mb-0"><a href="/Account/Login" class="text-success"><i class="bi bi-arrow-left me-1"></i> Quay lại đăng nhập</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>