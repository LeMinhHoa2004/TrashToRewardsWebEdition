@{
    ViewData["Title"] = "Xác thực OTP";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-lg-5 p-4">
                    <h2 class="text-center text-success fw-bold mb-4">Xác thực OTP</h2>

                    <form asp-action="VerifyOTP" method="post">
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">@ViewBag.Error</div>
                        }

                        <div class="mb-4">
                            <div class="form-floating">
                                <input type="text" name="otpInput" class="form-control" id="otpInput" maxlength="6" placeholder="Nhập 6 số OTP" required />
                                <label for="otpInput">Mã OTP</label>
                            </div>
                            <div class="form-text text-muted mt-2">
                                <i class="bi bi-info-circle me-1"></i> Vui lòng kiểm tra email để lấy mã OTP
                            </div>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold">Xác nhận</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>