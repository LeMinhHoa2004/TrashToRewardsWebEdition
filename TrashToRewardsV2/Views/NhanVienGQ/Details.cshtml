@model TrashToRewardsV2.Models.NHANVIENGQ

@{
    ViewData["Title"] = "Chi tiết nhân viên giao quà";
}

<div class="container py-4">
    <div class="bg-white bg-opacity-75 rounded p-4 mb-4">
        <h2 class="fw-bold text-success mb-3">Chi tiết nhân viên giao quà</h2>
    </div>

    <div class="card border-0 shadow-lg">
        <div class="card-body p-lg-5 p-4">
            <div class="row">
                <div class="col-md-4 text-center mb-4 mb-md-0">
                    <div class="p-3">
                        <i class="bi bi-person-circle text-success" style="font-size: 120px;"></i>
                        <h4 class="mt-3">@Model.HoTenNVGQ</h4>
                        <p class="text-muted">Mã nhân viên: @Model.MaNVGQ</p>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <tbody>
                                <tr class="hover-card">
                                    <th class="bg-light" style="width: 30%;">
                                        <i class="bi bi-envelope-fill text-success me-2"></i>Email
                                    </th>
                                    <td>@Model.EmailNVGQ</td>
                                </tr>
                                <tr class="hover-card">
                                    <th class="bg-light">
                                        <i class="bi bi-telephone-fill text-success me-2"></i>Điện thoại
                                    </th>
                                    <td>@Model.SDTNVGQ</td>
                                </tr>
                                <tr class="hover-card">
                                    <th class="bg-light">
                                        <i class="bi bi-box-seam-fill text-success me-2"></i>Kho quản lý
                                    </th>
                                    <td>@Model.KHOQUA?.TenKQ</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="text-center mt-4">
                <a asp-action="Index" class="btn btn-outline-success px-4 py-2 rounded-pill">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
                </a>
                <a asp-action="EditAdmin" asp-route-id="@Model.MaNVGQ" class="btn btn-success px-4 py-2 rounded-pill ms-2">
                    <i class="bi bi-pencil-fill me-2"></i>Chỉnh sửa
                </a>
            </div>
        </div>
    </div>
</div>