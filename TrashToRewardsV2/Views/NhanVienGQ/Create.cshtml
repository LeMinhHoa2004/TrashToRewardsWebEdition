@model TrashToRewardsV2.Models.NHANVIENGQ

@{
    ViewData["Title"] = "Thêm nhân viên giao quà";
}

<div class="container py-4">
    <div class="bg-white bg-opacity-75 rounded p-4 mb-4">
        <h2 class="fw-bold text-success mb-3">Thêm nhân viên giao quà</h2>
    </div>

    <div class="card border-0 shadow-lg">
        <div class="card-body p-lg-5 p-4">
            <form asp-action="Create" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                }
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="HoTenNVGQ" class="form-label fw-bold">Họ tên</label>
                        <div class="input-group">
                            <span class="input-group-text bg-success text-white"><i class="bi bi-person-fill"></i></span>
                            <input asp-for="HoTenNVGQ" class="form-control" placeholder="Nhập họ tên" />
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="EmailNVGQ" class="form-label fw-bold">Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-success text-white"><i class="bi bi-envelope-fill"></i></span>
                            <input asp-for="EmailNVGQ" class="form-control" placeholder="Nhập email" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SDTNVGQ" class="form-label fw-bold">Số điện thoại</label>
                        <div class="input-group">
                            <span class="input-group-text bg-success text-white"><i class="bi bi-telephone-fill"></i></span>
                            <input asp-for="SDTNVGQ" class="form-control" placeholder="Nhập số điện thoại" />
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="MatKhauNVGQ" class="form-label fw-bold">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-success text-white"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="MatKhauNVGQ" class="form-control" type="password" placeholder="Nhập mật khẩu" />
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Kho quản lý</label>
                    <div class="input-group">
                        <span class="input-group-text bg-success text-white"><i class="bi bi-box-seam-fill"></i></span>
                        <select asp-for="MaKQ" class="form-select" asp-items="ViewBag.KhoList"></select>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4 py-2 rounded-pill fw-bold">
                        <i class="bi bi-save me-2"></i>Lưu thông tin
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i>Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>