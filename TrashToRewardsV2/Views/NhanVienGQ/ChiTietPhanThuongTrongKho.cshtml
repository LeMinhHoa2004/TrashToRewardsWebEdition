@model TrashToRewardsV2.Models.CTKHOQUA

@{
    ViewData["Title"] = "Chi tiết Phần Thưởng";
}

<div class="container py-4">
    <div class="bg-white bg-opacity-75 rounded p-4 mb-4">
        <h2 class="fw-bold text-success mb-3">Chi tiết phần thưởng</h2>
    </div>

    <div class="card border-0 shadow-lg hover-card">
        <div class="card-body p-lg-5 p-4">
            <div class="row">
                <div class="col-md-5 mb-4 mb-md-0">
                    <div class="position-relative overflow-hidden rounded shadow-sm h-100" style="min-height: 300px;">
                        <img src="~/images/@Model.PHANTHUONG.HinhAnh" class="img-fluid rounded w-100 h-100" alt="@Model.PHANTHUONG.TenQua" style="object-fit: cover;">
                        <div class="position-absolute top-0 end-0 bg-success text-white px-3 py-2 m-2 rounded-pill">
                            <i class="bi bi-star-fill me-1"></i> @Model.PHANTHUONG.DiemDoi điểm
                        </div>
                    </div>
                </div>
                <div class="col-md-7">
                    <h3 class="text-success fw-bold mb-4">@Model.PHANTHUONG.TenQua</h3>

                    <div class="mb-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-success text-white rounded-circle p-2 me-3">
                                <i class="bi bi-box-seam"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">Kho quà</h6>
                                <p class="mb-0">@Model.KHOQUA.TenKQ</p>
                            </div>
                        </div>

                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-success text-white rounded-circle p-2 me-3">
                                <i class="bi bi-123"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">Số lượng còn lại</h6>
                                <p class="mb-0">@Model.SoLuongTrongKho</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.PHANTHUONG.MoTa))
                        {
                            <div class="d-flex align-items-center">
                                <div class="bg-success text-white rounded-circle p-2 me-3">
                                    <i class="bi bi-info-circle"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">Mô tả</h6>
                                    <p class="mb-0">@Model.PHANTHUONG.MoTa</p>
                                </div>
                            </div>
                        }
                    </div>

                    <a asp-action="DanhSachPhanThuongTrongKho" class="btn btn-outline-success px-4 py-2 rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>