@model IEnumerable<TrashToRewardsV2.Models.CTKHOQUA>

@{
    ViewData["Title"] = "Phần Thưởng Trong Kho";
}

<div class="container py-4">
    <div class="bg-white bg-opacity-75 rounded p-4 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="fw-bold text-success mb-0">Phần thưởng trong kho: @ViewBag.KhoTen</h2>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-lg h-100 hover-card">
                    <div class="position-relative">
                        <img src="~/images/@item.PHANTHUONG.HinhAnh" class="card-img-top" alt="@item.PHANTHUONG.TenQua" style="height: 200px; object-fit: cover;">
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge bg-success rounded-pill">
                                <i class="bi bi-star-fill me-1"></i> @item.PHANTHUONG.DiemDoi điểm
                            </span>
                        </div>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-success">@item.PHANTHUONG.TenQua</h5>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="text-muted"><i class="bi bi-box-seam me-1"></i> Còn: @item.SoLuongTrongKho</span>
                            <a asp-action="ChiTietPhanThuongTrongKho" asp-route-maQua="@item.MaQua" class="btn btn-outline-success rounded-pill">
                                <i class="bi bi-info-circle me-1"></i>Chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>