@model PHIEUDATLICH

@{
    ViewData["Title"] = "Đặt lịch thu gom";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-success text-white p-3">
                    <h4 class="mb-0"><i class="bi bi-calendar-plus me-2"></i>Đặt lịch thu gom phế liệu</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                        }
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-4">
                            <label asp-for="NgayDL" class="control-label fw-bold mb-2">Ngày giờ thu gom</label>
                            <div class="input-group">
                                <span class="input-group-text bg-success text-white">
                                    <i class="bi bi-calendar-event"></i>
                                </span>
                                <input type="text" id="ngayDL" name="NgayDL" class="form-control form-control-lg" placeholder="dd/MM/yyyy HH:mm" />

                            </div>
                            <span asp-validation-for="NgayDL" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="DiaDiemDL" class="control-label fw-bold mb-2">Địa điểm thu gom</label>
                            <div class="input-group">
                                <span class="input-group-text bg-success text-white"><i class="bi bi-geo-alt"></i></span>
                                <input asp-for="DiaDiemDL" class="form-control form-control-lg" placeholder="Nhập địa chỉ chi tiết..." />
                            </div>
                            <span asp-validation-for="DiaDiemDL" class="text-danger"></span>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-success btn-lg px-4 rounded-pill">
                                <i class="bi bi-calendar-check me-2"></i>Đặt lịch
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại
                            </a>
                        </div>

                        @if (TempData["Errors"] != null)
                        {
                            <div class="alert alert-danger mt-3">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Errors"]
                            </div>
                        }
                    </form>
                </div>
            </div>
            <div class="text-center text-muted mt-4">
                <p><i class="bi bi-info-circle me-2"></i>Vui lòng chọn thời gian phù hợp để chúng tôi có thể sắp xếp thu gom</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <!-- Flatpickr JS & CSS -->
    <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>

    <script>
        flatpickr("#ngayDL", {
            enableTime: true,
            dateFormat: "d/m/Y H:i",
            time_24hr: true,
            locale: "vn",
            minDate: "today"
        });
    </script>
}
