@model IEnumerable<TrashToRewardsV2.Models.DONVITHUGOM>
@{
    ViewData["Title"] = "Danh sách đơn vị thu gom";
}

<div class="container py-5">
    <div class="bg-white bg-opacity-75 rounded p-4 mb-5">
        <div class="row">
            <div class="col-md-8 mx-auto text-center">
                <div class="d-flex align-items-center justify-content-center mb-3">
                    <i class="bi bi-building-fill text-success me-3" style="font-size: 2.5rem;"></i>
                    <h2 class="text-success fw-bold mb-0">@ViewData["Title"]</h2>
                </div>
                <p class="lead text-muted">Các đơn vị thu gom hợp tác với TrashToRewards</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var dv in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100 hover-card">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <i class="bi bi-recycle text-success fs-1"></i>
                        </div>
                        <h5 class="card-title text-success text-center fw-bold mb-3">@dv.TenDV</h5>
                        <div class="card-text">
                            <div class="d-flex mb-2">
                                <i class="bi bi-geo-alt-fill text-success me-2 mt-1"></i>
                                <div>
                                    <strong>Địa chỉ:</strong><br />
                                    @dv.DiaChiDV
                                </div>
                            </div>
                            <div class="d-flex">
                                <i class="bi bi-telephone-fill text-success me-2 mt-1"></i>
                                <div>
                                    <strong>Số điện thoại:</strong><br />
                                    @dv.SDTDV
                                </div>
                            </div>
                        </div>
                    </div>
                    @* <div class="card-footer bg-transparent border-0 text-center p-3"> *@
                    @*     <a href="#" class="btn btn-outline-success rounded-pill px-4"> *@
                    @*         <i class="bi bi-info-circle-fill me-2"></i>Chi tiết *@
                    @*     </a> *@
                    @* </div> *@
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-5">
        <a href="/" class="btn btn-success btn-lg rounded-pill px-5">
            <i class="bi bi-house-fill me-2"></i>Về trang chủ
        </a>
    </div>
</div>