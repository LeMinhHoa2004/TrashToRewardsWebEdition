@model IEnumerable<TrashToRewardsV2.Models.PHIEUGHINHAN>

@{
    ViewData["Title"] = "Danh sách phiếu ghi nhận";
}

<div class="container py-4">
    <div class="card border-0 shadow-lg mb-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="fw-bold text-success mb-0">Danh sách phiếu ghi nhận</h2>
                <a asp-action="Create" class="btn btn-success px-4 rounded-pill">
                    <i class="bi bi-plus-circle me-2"></i> Tạo phiếu ghi nhận
                </a>
            </div>

            <div class="table-responsive mt-4">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Mã phiếu</th>
                            <th>Người dùng</th>
                            <th>Nhân viên</th>
                            <th>Ngày ghi nhận</th>
                            <th>Tổng điểm</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="align-middle">
                                <td>@item.MaPhieuGN</td>
                                <td>@item.NGUOIDUNG?.HoTen</td>
                                <td>@item.NHANVIEN?.HoTenNV</td>
                                <td>@item.NgayGhiNhan.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-success fw-bold">@item.TongDiemGN</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.MaPhieuGN" class="btn btn-outline-success btn-sm rounded-pill">
                                        <i class="bi bi-eye me-1"></i> Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-clipboard-x text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3">Chưa có phiếu ghi nhận nào.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add animation on hover for table rows
        document.querySelectorAll('tbody tr').forEach(row => {
            row.addEventListener('mouseover', function() {
                this.classList.add('shadow-sm');
            });

            row.addEventListener('mouseout', function() {
                this.classList.remove('shadow-sm');
            });
        });
    </script>
}