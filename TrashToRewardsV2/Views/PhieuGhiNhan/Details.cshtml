@model TrashToRewardsV2.Models.PHIEUGHINHAN

@{
    ViewData["Title"] = "Chi tiết phiếu ghi nhận";
}

<div class="container py-4">
    <div class="bg-white bg-opacity-75 rounded p-4 shadow-sm mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-success fw-bold mb-0">
                <i class="bi bi-file-text me-2"></i>Chi tiết phiếu ghi nhận
            </h2>
            <span class="badge bg-success p-2">Mã phiếu: #@Model.MaPhieuGN</span>
        </div>
        
        <div class="card border-0 shadow-sm hover-card mb-4">
            <div class="card-body p-4">
                <h4 class="card-title text-success mb-3">
                    <i class="bi bi-info-circle me-2"></i>Thông tin chung
                </h4>
                
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card bg-light h-100">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <i class="bi bi-person me-2"></i>Thông tin người dùng
                                </h5>
                                <ul class="list-unstyled mt-3">
                                    <li class="mb-2">
                                        <i class="bi bi-person-fill text-success me-2"></i>
                                        <strong>Họ tên:</strong> @Model.NGUOIDUNG?.HoTen
                                    </li>
                                    @if (Model.NGUOIDUNG?.Email != null)
                                    {
                                        <li class="mb-2">
                                            <i class="bi bi-envelope text-success me-2"></i>
                                            <strong>Email:</strong> @Model.NGUOIDUNG.Email
                                        </li>
                                    }
                                    @if (Model.NGUOIDUNG?.SDT != null)
                                    {
                                        <li>
                                            <i class="bi bi-telephone text-success me-2"></i>
                                            <strong>SĐT:</strong> @Model.NGUOIDUNG.SDT
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-light h-100">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <i class="bi bi-calendar-check me-2"></i>Thông tin ghi nhận
                                </h5>
                                <ul class="list-unstyled mt-3">
                                    <li class="mb-2">
                                        <i class="bi bi-person-badge text-success me-2"></i>
                                        <strong>Nhân viên ghi nhận:</strong> @Model.NHANVIEN?.HoTenNV
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-calendar2 text-success me-2"></i>
                                        <strong>Ngày ghi nhận:</strong> @Model.NgayGhiNhan.ToString("dd/MM/yyyy HH:mm")
                                    </li>
                                    <li>
                                        <i class="bi bi-star-fill text-warning me-2"></i>
                                        <strong>Tổng điểm:</strong> 
                                        <span class="text-success fw-bold fs-5">@Model.TongDiemGN</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm hover-card">
            <div class="card-body p-4">
                <h4 class="card-title text-success mb-3">
                    <i class="bi bi-list-check me-2"></i>Chi tiết phế liệu ghi nhận
                </h4>
                
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Loại phế liệu</th>
                                <th>Khối lượng</th>
                                <th>Điểm nhận được</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ct in Model.CTPHIEUGHINHANs)
                            {
                                <tr>
                                    <td>
                                        @ct.LOAIPHELIEU?.TenLoai
                                    </td>
                                    <td>@ct.KhoiLuongGN @ct.LOAIPHELIEU?.DonVi</td>
                                    <td class="text-success fw-bold">@ct.SoDiemNhanDuocGN</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="2" class="text-end fw-bold">Tổng điểm:</td>
                                <td class="text-success fw-bold">@Model.TongDiemGN</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                
                @if (!Model.CTPHIEUGHINHANs.Any())
                {
                    <div class="alert alert-info text-center">
                        <i class="bi bi-info-circle me-2"></i>Không có chi tiết nào được ghi nhận
                    </div>
                }
            </div>
        </div>

        <div class="text-end mt-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
            </a>
        </div>
    </div>
</div>