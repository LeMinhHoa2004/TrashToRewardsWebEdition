@model IEnumerable<TrashToRewardsV2.Models.PHIEUGHINHAN>

@{
    ViewData["Title"] = "Danh sách Phiếu Ghi Nhận";
}

<div class="container mt-4">
    <h2 class="fw-bold text-success d-flex align-items-center mb-4">
        <i class="bi bi-journal-text-fill me-2 fs-3"></i> Danh sách Phiếu Ghi Nhận
    </h2>


    <div class="card shadow-sm">
        <div class="card-header bg-success text-white fw-bold">
            <i class="bi bi-card-checklist me-2"></i>Tất cả phiếu ghi nhận
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center text-muted p-4">Chưa có phiếu ghi nhận nào</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã Phiếu</th>
                                <th>Ngày Ghi Nhận</th>
                                <th>Tổng Điểm</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var phieu in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@phieu.MaPhieuGN</td>
                                    <td>@phieu.NgayGhiNhan.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-success fw-bold">@phieu.TongDiemGN</td>
                                    <td>
                                        <a asp-action="PhieuGhiNhanDetails" asp-route-id="@phieu.MaPhieuGN" class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-info-circle me-1"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>